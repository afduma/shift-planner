# Spring profile (dev, prod, etc.)
SPRING_PROFILES_ACTIVE=dev

# Database configuration
DB_NAME=shiftplanner
DB_USER=shiftplanner
DB_PASSWORD=shiftplanner
DB_PORT=5433

# Optional: full DB URL override
# DB_URL=jdbc:postgresql://localhost:5433/shiftplanner

# JWT configuration
JWT_SECRET=change-me-demo-secret-change-me-demo-secret
JWT_EXPIRATION_SECONDS=3600

# Development seeding
SEED_ENABLED=true
SEED_ADMIN_PASSWORD=admin123
SEED_USER_COUNT=15
SEED_TEAM_COUNT=3
